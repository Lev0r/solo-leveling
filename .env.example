# Copy to .env.local (gitignored) and fill in values from
# Firebase console → Project settings → Your apps → Web app config.
# These are PUBLIC web API keys — they identify the project, not authorize it.
# Access control is enforced by Firestore security rules + the whitelist.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=solo-leveling-fa230.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=solo-leveling-fa230
VITE_FIREBASE_STORAGE_BUCKET=solo-leveling-fa230.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" for local dev against the Firebase emulator suite.
# .env.development (committed) sets this true; .env.production sets this false.
VITE_USE_EMULATOR=false
